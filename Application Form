<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rental Application</title>

<style>
body{
font-family:Arial,sans-serif;
background:#f4f7fb;
margin:0;
}

.header{
background:#0d6efd;
color:white;
padding:30px;
text-align:center;
}

.container{
max-width:750px;
margin:30px auto;
background:white;
padding:30px;
border-radius:12px;
box-shadow:0 5px 20px rgba(0,0,0,.1);
}

input,select,textarea{
width:100%;
padding:12px;
margin-top:8px;
margin-bottom:18px;
border:1px solid #ccc;
border-radius:8px;
font-size:16px;
}

button{
width:100%;
padding:15px;
background:#198754;
color:white;
border:none;
border-radius:8px;
font-size:18px;
cursor:pointer;
}

button:hover{
background:#157347;
}

.footer{
text-align:center;
padding:20px;
color:#666;
}
</style>

</head>

<body>

<div class="header">
<h1>Rental Application</h1>
<p>Complete the application below.</p>
</div>

<div class="container">

<form>

<label>Full Name</label>
<input type="text" required>

<label>Email Address</label>
<input type="email" required>

<label>Phone Number</label>
<input type="tel" required>

<label>Current Address</label>
<input type="text">

<label>Monthly Income</label>
<input type="number">

<label>Move-in Date</label>
<input type="date">

<label>Number of Occupants</label>
<select>
<option>1</option>
<option>2</option>
<option>3</option>
<option>4+</option>
</select>

<label>Additional Information</label>
<textarea rows="5"></textarea>

<button type="submit">
Submit Application
</button>

</form>

</div>

<div class="footer">
© 2026 Rental Marketplace. All rights reserved.
</div>

</body>
</html>
